rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/botGames/{skillLevel} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/offlineGame/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }
    match /matches/{matchId} {
      allow create: if request.auth != null
        && request.resource.data.bluePlayer.uid == request.auth.uid;
      allow read: if request.auth != null
        && (
          resource.data.status == 'waiting'
          || request.auth.uid in resource.data.participantIds
        );
      allow update: if request.auth != null
        && (
          request.auth.uid in resource.data.participantIds
          || (
            resource.data.status == 'waiting'
            && resource.data.orangePlayer == null
            && request.resource.data.orangePlayer.uid == request.auth.uid
          )
        );
    }
  }
}
